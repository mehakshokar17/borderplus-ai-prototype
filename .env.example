# ── BorderPlus AI environment ───────────────────────────────────────────────
# The app runs fully in MOCK MODE with no keys. Add a key to enable real models.
#
# Provider priority: Gemini → OpenRouter → OpenAI → mock.

# Google Gemini (primary) — most reliable. Get a STANDARD key (starts with "AIza")
# at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Use gemini-2.5-flash (broad free-tier access). Note: some projects have ZERO
# free quota on gemini-2.0-flash, so prefer 2.5-flash.
GEMINI_MODEL=gemini-2.5-flash

# OpenRouter (fallback) — one key, many models; free models use a ":free" suffix,
# but the shared free pool throttles (50 req/day). Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemma-4-31b-it:free

# OpenAI (fallback) — used only if no Gemini key is set. Enables GPT-4o + Whisper.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Optional: ElevenLabs for premium AI voice. If empty, the app uses the
# browser's built-in SpeechSynthesis (no key required).
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

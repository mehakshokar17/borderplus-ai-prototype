# ── BorderPlus AI environment ───────────────────────────────────────────────
# The app runs fully in MOCK MODE with no keys. Add a key to enable real models.
#
# Provider priority: OpenRouter → Gemini → OpenAI → mock.

# OpenRouter (primary) — one key, many models. Free models use a ":free" suffix.
# Get a free key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Optional: override the model. Some free options:
#   meta-llama/llama-3.3-70b-instruct:free   (default)
#   deepseek/deepseek-chat-v3-0324:free
#   google/gemini-2.0-flash-exp:free
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# Google Gemini (fallback) — also powers voice transcription (multimodal).
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional: override the Gemini model
GEMINI_MODEL=gemini-2.5-flash

# OpenAI (fallback) — used only if no Gemini key is set. Enables GPT-4o + Whisper.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Optional: ElevenLabs for premium AI voice. If empty, the app uses the
# browser's built-in SpeechSynthesis (no key required).
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
